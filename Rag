from fastapi import FastAPI, Header, HTTPException
from pydantic import BaseModel
import uvicorn

from haystack import Pipeline
from haystack.components.rankers import SentenceTransformersSimilarityRanker
from haystack_integrations.document_stores.qdrant import QdrantDocumentStore
from haystack_integrations.components.retrievers.qdrant import QdrantEmbeddingRetriever
from haystack_integrations.components.embedders.ollama import OllamaTextEmbedder
from haystack_integrations.components.embedders.fastembed import FastembedSparseTextEmbedder

# --- SETUP ---
API_KEY = "mein_geheimer_schlüssel_123" # In Open WebUI hinterlegen
document_store = QdrantDocumentStore(host="localhost", index="EnterpriseHybridDocs", use_sparse_embeddings=True)

app = FastAPI(title="Industrial RAG Tool Server")

# --- HYBRID RETRIEVAL PIPELINE ---
rag_pipe = Pipeline()

# Zweig 1: Semantische Suche (Dense)
rag_pipe.add_component("dense_text_embedder", OllamaTextEmbedder(
    model="nomic-embed-text-v2-moe", 
    prefix="search_query: "
))

# Zweig 2: Keyword Suche (Sparse)
rag_pipe.add_component("sparse_text_embedder", FastembedSparseTextEmbedder(model="Qdrant/bm25"))

# Hybrid Retriever (kombiniert beides automatisch)
rag_pipe.add_component("retriever", QdrantEmbeddingRetriever(document_store=document_store, top_k=20))

# Reranker (Die Qualitätsstufe)
rag_pipe.add_component("reranker", SentenceTransformersSimilarityRanker(
    model="BAAI/bge-reranker-base", 
    top_k=5
))

# Verbindungen
rag_pipe.connect("dense_text_embedder.embedding", "retriever.query_embedding")
rag_pipe.connect("sparse_text_embedder.sparse_embedding", "retriever.query_sparse_embedding")
rag_pipe.connect("retriever.documents", "reranker.documents")

class QueryModel(BaseModel):
    query: str

# --- TOOL ENDPUNKT ---
@app.post("/search")
async def search_enterprise_docs(request: QueryModel, authorization: str = Header(None)):
    """
    Durchsucht Firmendokumente mittels Hybrid-Search (Vektoren + Keywords). 
    Findet technische Details, Seriennummern und Konzepte.
    """
    # Sicherheit Check
    if not authorization or authorization != f"Bearer {API_KEY}":
        raise HTTPException(status_code=401, detail="Unauthorized")

    try:
        # Pipeline ausführen
        results = rag_pipe.run({
            "dense_text_embedder": {"text": request.query},
            "sparse_text_embedder": {"text": request.query},
            "reranker": {"query": request.query}
        })

        docs = results["reranker"]["documents"]
        
        # Antwort für das LLM in Open WebUI formatieren
        response_text = "Relevante Informationen aus der Wissensdatenbank:\n\n"
        for d in docs:
            source = d.meta.get("file_name", "Unbekannt")
            score = round(d.score, 2)
            response_text += f"--- QUELLE: {source} (Relevanz: {score}) ---\n{d.content}\n\n"
        
        return {"result": response_text}

    except Exception as e:
        print(f"Fehler: {e}")
        raise HTTPException(status_code=500, detail="Interner Serverfehler bei der Suche.")

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=8000)
             
