import os
from pathlib import Path
from haystack import Pipeline
from haystack.components.converters import PyPDFToDocument
from haystack.components.preprocessors import DocumentCleaner, DocumentSplitter
from haystack.components.writers import DocumentWriter
from haystack_integrations.document_stores.qdrant import QdrantDocumentStore
from haystack_integrations.components.embedders.ollama import OllamaDocumentEmbedder
from haystack_integrations.components.embedders.fastembed import FastembedSparseDocumentEmbedder

# --- KONFIGURATION ---
QDRANT_HOST = "localhost"
INDEX_NAME = "EnterpriseHybridDocs"
PDF_DIR = "./data" # Erstelle diesen Ordner und lege PDFs hinein

def run_ingestion():
    # 1. Store mit Hybrid-Unterstützung initialisieren
    document_store = QdrantDocumentStore(
        host=QDRANT_HOST,
        index=INDEX_NAME,
        embedding_dim=768,       # Dimension für Nomic V2
        use_sparse_embeddings=True, # Aktiviert Sparse-Vektoren für Keywords
        recreate_index=False
    )

    # 2. Komponenten definieren
    converter = PyPDFToDocument()
    cleaner = DocumentCleaner(remove_empty_lines=True, remove_extra_whitespaces=True)
    splitter = DocumentSplitter(split_by="word", split_length=250, split_overlap=30)
    
    # Dense Embedder (Nomic via Ollama)
    dense_embedder = OllamaDocumentEmbedder(
        model="nomic-embed-text-v2-moe",
        url="http://localhost:11434/api/embeddings",
        prefix="search_document: "
    )
    
    # Sparse Embedder (Lokales BM25 via Fastembed - extrem schnell)
    sparse_embedder = FastembedSparseDocumentEmbedder(model="Qdrant/bm25")
    
    writer = DocumentWriter(document_store=document_store)

    # 3. Pipeline aufbauen
    pipeline = Pipeline()
    pipeline.add_component("converter", converter)
    pipeline.add_component("cleaner", cleaner)
    pipeline.add_component("splitter", splitter)
    pipeline.add_component("dense_embedder", dense_embedder)
    pipeline.add_component("sparse_embedder", sparse_embedder)
    pipeline.add_component("writer", writer)

    # Verbindungen (Splitter geht in beide Embedder)
    pipeline.connect("converter", "cleaner")
    pipeline.connect("cleaner", "splitter")
    pipeline.connect("splitter", "dense_embedder")
    pipeline.connect("dense_embedder", "sparse_embedder")
    pipeline.connect("sparse_embedder", "writer")

    # 4. Ausführen
    pdf_path = Path(PDF_DIR)
    if not pdf_path.exists():
        pdf_path.mkdir()
    
    files = [pdf_path / f for f in os.listdir(pdf_path) if f.endswith(".pdf")]
    if files:
        print(f"Verarbeite {len(files)} Dokumente...")
        pipeline.run({"converter": {"sources": files}})
        print("Indexing abgeschlossen.")
    else:
        print("Keine PDFs gefunden. Bitte PDFs in den Ordner ./data legen.")

if __name__ == "__main__":
    run_ingestion()





